// Minimal niri config for the greetd session.
// Lives at /etc/niri/greeter.kdl
// Niri is only here to give the greeter a Wayland compositor — keep it bare.

environment {
    // Make sure GTK picks up the Wayland backend
    GDK_BACKEND "wayland"
}

input {
    keyboard {
        xkb {
            // Match your layout
            layout "gb"
        }
    }
}

layout {
    gaps 0
    border {
        off
    }
}

window-rule {
    geometry-corner-radius 0
    clip-to-geometry true
}
